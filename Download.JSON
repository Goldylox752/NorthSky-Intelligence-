let lastRipResult = null; // Global variable to store the latest data

async function executeRip() {
    // ... your existing fetch logic ...
    const data = await res.json();
    lastRipResult = data; // Store the data for downloading
    // ... rest of your code ...
}

function downloadJSON() {
    if (!lastRipResult) return;

    // 1. Create a Blob from the JSON data
    const blob = new Blob([JSON.stringify(lastRipResult, null, 2)], { type: 'application/json' });
    
    // 2. Create a temporary URL for the Blob
    const url = URL.createObjectURL(blob);
    
    // 3. Create a hidden <a> tag and click it
    const link = document.createElement('a');
    link.href = url;
    
    // Use the URL or title as the filename
    const filename = `rip_${Date.now()}.json`;
    link.download = filename;
    
    document.body.appendChild(link);
    link.click();
    
    // 4. Cleanup
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
}
